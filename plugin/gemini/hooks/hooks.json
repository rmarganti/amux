{
  "hooks": {
    "BeforeAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${extensionPath}/hooks/amux-status.sh",
            "name": "amux-status",
            "timeout": 5000
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${extensionPath}/hooks/amux-status.sh",
            "name": "amux-status",
            "timeout": 5000
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${extensionPath}/hooks/amux-status.sh",
            "name": "amux-status",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${extensionPath}/hooks/amux-status.sh",
            "name": "amux-status",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
